<html lang="en">
  <head>
    {{#with meta}}
      {{#if title}}<title>{{title}}</title>{{/if}}
      {{#if description}}
        <meta name="description" content="{{description}}" />
      {{/if}}
      {{#if robots}}<meta name="robots" content="{{join robots ','}}" />{{/if}}
      {{#if rating}}<meta name="rating" content="{{rating}}" />{{/if}}

      {{#if ogTitle}}<meta property="og:title" content="{{ogTitle}}" />{{/if}}
      {{#if ogDescription}}
        <meta property="og:description" content="{{ogDescription}}" />
      {{/if}}
      {{#if canonicalURL}}
        <meta property="og:url" content="{{canonicalURL}}" />
      {{/if}}

      <!-- TODO -->
      <meta name="og:image" content="" />
      <meta name="og:type" content="article" />
      <meta name="og:site_name" content="" />
      <meta name="og:locale" content="" />

      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      {{#if canonicalURL}}
        <link rel="canonical" href="{{canonicalURL}}" />
      {{/if}}
    {{/with}}

    <link rel="stylesheet" href="/asset/index.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/daisyui@5"
      rel="stylesheet"
      type="text/css"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/daisyui@5/themes.css"
      rel="stylesheet"
      type="text/css"
    />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- HTMX -->
    <script src="https://unpkg.com/htmx.org@2.0.6"></script>
    <script src="/asset/index.js" defer></script>
  </head>
  <body>
    <header>
      <div class="container">
        <div class="page-title">My Awesome Page</div>
        <nav>
          <ul>
            <li><a href="#">Home</a></li>
            <li><a href="#">About</a></li>
            <li><a href="#">Services</a></li>
            <li><a href="#">Contact</a></li>
            {{#eachMenuItem}}
              <li><a href="/{{@menu}}">{{@menu}}</a></li>
            {{/eachMenuItem}}
            <li>
              <a href="#" class="search-icon"><i class="fas fa-search"></i></a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <div class="search-popup" id="searchPopup">
      <div class="search-popup-content">
        <span class="close-search" id="closeSearch">&times;</span>
        <h2>Search Articles</h2>
        <input type="text" id="searchInput" placeholder="Enter keywords..." />
        <button id="searchButton">Search</button>
      </div>
    </div>

    <main class="container page-body">
      {{body}}
    </main>

    <footer>
      <div class="container footer-content">
        <div class="minor-links">
          <ul>
            <li><a href="#">Privacy Policy</a></li>
            <li><a href="#">Terms of Service</a></li>
            <li><a href="#">About Us</a></li>
          </ul>
        </div>
        <div class="social-icons">
          <a href="#" aria-label="Facebook"><i
              class="fab fa-facebook-f"
            ></i></a>
          <a href="#" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
          <a href="#" aria-label="Instagram"><i
              class="fab fa-instagram"
            ></i></a>
          <a href="#" aria-label="LinkedIn"><i
              class="fab fa-linkedin-in"
            ></i></a>
        </div>
      </div>
    </footer>

    {{#equal meta.rating "adult"}}
      <dialog id="age-modal" class="modal">
        <div class="modal-backdrop"><div class="backdrop-blur-sm"></div></div>
        <div class="modal-box">
          <h3 class="font-bold text-lg">Age Verification</h3>
          <p>This content is intended for adults only (18+).<br />
            By continuing, you confirm that you are of legal age in your
            jurisdiction.</p>
          <div class="modal-action"><button
              id="age-confirm-btn"
              class="btn btn-primary"
            >I am 18+ years old</button></div>
        </div>
      </dialog>
    {{/equal}}
  </body>
</html>
