<div class="bg-base-100 p-6 rounded-box shadow">
  <form
    method="POST"
    action="/admin/page/save/{{class}}"
    id="edit-page-form"
    name="edit-page-form"
  >
    <div class="mb-6 flex justify-between items-center">
      <div>
        <h1 class="text-3xl font-bold">Edit {{class}} page</h1>
        <input type="hidden" name="identifier" value="{{identifier}}" />
      </div>
      <div class="form-control">
        <label class="label cursor-pointer gap-2">
          <span class="label-text">Enabled</span>
          <input
            type="checkbox"
            name="is-enabled"
            class="toggle toggle-success"
            {{#if page.isEnabled}}checked{{/if}}
          />
        </label>
      </div>
    </div>

    <div class="mb-6">
      <details class="collapse collapse-arrow bg-secondary/10 border border-secondary/30 rounded-lg">
        <summary class="collapse-title text-sm font-semibold text-secondary after:start-5 after:end-auto ps-12">Meta</summary>
        <div class="collapse-content border-t border-secondary/30">
          <div class="form-control mb-4">
            <label class="label" for="route">
              <span class="label-text">route</span>
            </label>
            <div id="route-wrapper">
              <input
                type="text"
                id="route"
                name="route"
                class="input input-bordered w-full validator"
                placeholder="/{{class}}/{{identifier}}"
                value="{{page.route}}"
                hx-post="/admin/page/get-valid-slug"
                hx-trigger="blur"
                hx-on:htmx:before-request="document.getElementById('route').setCustomValidity(''); document.getElementById('route-error').classList.add('hidden');"
                hx-on:htmx:after-request="if (event.detail.failed) {
                  document.getElementById('route').setCustomValidity(event.detail.xhr.response);
                  with (document.getElementById('route-error')) {
                    innerHTML=event.detail.xhr.response;
                    classList.remove('hidden');
                  };
                } else {
                  document.getElementById('route').value=event.detail.xhr.response;
                }"
              />
              <div id="route-error" class="validator-hint hidden"></div>
            </div>
          </div>

          <div class="divider"></div>

          <!-- Meta Title -->
          <div class="form-control mb-4">
            <label class="label" for="meta-title">Meta Title</label>
            <input
              type="text"
              id="meta-title"
              name="meta-title"
              class="input input-bordered w-full"
              placeholder="{{page.secondaryIdentifierValue}}"
              value="{{page.meta.title}}"
              data-soft-limit="60"
            />
          </div>

          <!-- Meta Description -->
          <div class="form-control mb-4">
            <label class="label" for="meta-description">Meta Description</label>
            <textarea
              id="meta-description"
              name="meta-description"
              class="textarea textarea-bordered w-full"
              data-soft-limit="160"
            >{{page.meta.description}}</textarea>
          </div>

          
          <!-- Robots -->
          <div class="form-control mb-4">
            <label class="label">robots directive</label>
            <div class="flex gap-4">
              <label class="label cursor-pointer gap-2">
                <input
                  type="checkbox"
                  name="meta-robots-noindex"
                  class="checkbox"
                  {{#contains page.meta.robots "noindex"}}checked{{/contains}}
                />
                <span class="label-text">noindex</span>
              </label>
              <label class="label cursor-pointer gap-2">
                <input
                  type="checkbox"
                  name="meta-robots-nofollow"
                  class="checkbox"
                  {{#contains page.meta.robots "nofollow"}}checked{{/contains}}
                />
                <span class="label-text">nofollow</span>
              </label>
            </div>
          </div>

          <!-- Rating -->
          <div class="form-control mb-4">
            <label class="label cursor-pointer gap-2">
              <input
                type="checkbox"
                name="meta-rating-adult"
                class="checkbox"
                {{#equal page.meta.rating "adult"}}checked{{/equal}}
              />
              <span class="label-text">Adult content (18+)</span>
            </label>
          </div>

          <!-- Open Graph Section -->
          <div class="divider"></div>
          <h3 class="text-lg font-bold mb-4">Open Graph</h3>

          <!-- OG Title -->
          <div class="form-control mb-4">
            <label class="label" for="meta-og-title">OG Title</label>
            <input
              type="text"
              id="meta-og-title"
              name="meta-og-title"
              class="input input-bordered w-full"
              placeholder="{{page.secondaryIdentifierValue}}"
              value="{{page.meta.OGTitle}}"
              data-soft-limit="60"
            />
          </div>

          <!-- OG Description -->
          <div class="form-control mb-4">
            <label class="label" for="meta-og-description">OG Description</label>
            <textarea
              id="meta-og-description"
              name="meta-og-description"
              class="textarea textarea-bordered w-full"
              data-soft-limit="300"
            >{{page.meta.OGDescription}}</textarea>
          </div>

        </div>
      </details>
    </div>

    <div class="space-y-4">
      {{#each page.fields}}
        <div class="form-control">
          <label class="label" for="{{name}}">
            <span
              class="label-text
                {{compareAndUse
                  'text-primary font-bold'
                  true
                  page.identifier
                  name
                }}
                {{compareAndUse
                  'text-secondary font-bold'
                  true
                  page.secondaryIdentifier
                  name
                }}
                "
            >{{name}}
              {{#if isMandatory}}
                <span class="text-error">*</span>
              {{/if}}
              {{#if isListable}}
                <i class="fa-solid fa-list"></i>
              {{/if}}
              {{#if isSearchable}}
                <i class="fa-solid fa-magnifying-glass searchable-icon"></i>
              {{/if}}
            </span>
          </label>

          {{#equal component "TextArea"}}
            <textarea id="field-{{name}}" name="field-{{name}}"
              class="textarea textarea-bordered w-full {{use 'validator' true isMandatory}}"
              {{use "required" true isMandatory}}>{{value}}</textarea>
          {{/equal}}
          {{#equal component "Checkbox"}}
            {{#if isMandatory}}
              <input type="checkbox" id="field-{{name}}" name="field-{{name}}" {{use 'checked' true value}}/>
            {{else}}
              <select name="field-{{name}}" class="select select-bordered w-full">
               <option value="" {{#unless value}}selected{{/unless}}>—</option>
               <option value="true" {{use 'selected' true value}}>True</option>
               <option value="false" {{use 'selected' false value}}>False</option>
              </select>
            {{/if}}
          {{/equal}}  
          {{#equal component "ReferenceSearch"}}
            <div class="flex gap-2">
              <input type="text" id="field-{{name}}" name="field-{{name}}"
                value="{{value}}" class="input input-bordered w-full"
                placeholder="#ZHERO#Type/123#{'linkText':'...','altText':'...'}#"
                data-field-name="{{name}}" data-schema="{{class}}" />
              <button type="button" class="btn btn-secondary"
                hx-get="/admin/page/reference-modal?schema={{class}}&field={{name}}"
                hx-target="#modal-container" hx-push-url="false">
                Search
              </button>
            </div>
            {{#if references}}
              <div class="text-sm text-info mt-1">References: {{references.length}}</div>
            {{/if}}
          {{/equal}}
          {{#if inputType}} 
            <input type="{{component}}" id="field-{{name}}" name="field-{{name}}"
              class="input input-bordered w-full {{use 'validator' true isMandatory}}"
              value="{{value}}" {{use "required" true isMandatory}} />
          {{/if}}
          {{#equal component "TextInput"}}
            <input type="text" id="field-{{name}}" name="field-{{name}}"
              class="input input-bordered w-full {{use 'validator' true isMandatory}}"
              value="{{value}}" {{use "required" true isMandatory}}
              data-field-name="{{name}}" data-schema="{{class}}" />
          {{/equal}}

          {{#if isMandatory}}
            <div class="validator-hint">{{name}} is required.</div>
          {{/if}}
        </div>
      {{/each}}
    </div>

   <!--
        <input
          type="file"
          id="featured-image"
          name="featured-image"
          class="file-input file-input-bordered w-full"
        />
-->

    <div class="flex justify-end space-x-2 mt-6">
      <button
        type="button"
        class="btn btn-info"
        onclick="submitPreview('{{class}}')"
      >
        <i class="fas fa-eye"></i>
        Preview
      </button>
      <button
        type="button"
        class="btn btn-error"
        onclick="window.location.href = '/admin/page/list?schema={{class}}'"
      >
        <i class="fas fa-circle-xmark"></i>
        Cancel
      </button>
      <button type="submit" class="btn btn-success">
        {{#if identifier}}
          <i class="fas fa-floppy-disk"></i>Update
        {{else}}
          <i class="fas fa-circle-plus"></i>Create
        {{/if}}
      </button>
    </div>
  </form>
</div>
